# ===============================
# App settings
# ===============================
APP_NAME=Stock Assistant
APP_VERSION=0.1.0
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_ENVIRONMENT=development

# ===============================
# API Keys (sensitive)
# ===============================
APP_OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
APP_TAVILY_API_KEY=<YOUR_TAVILY_API_KEY>
APP_GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# ===============================
# LLM settings
# ===============================
LLM_DEFAULT_PROVIDER=gemini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# OpenAI
LLM_OPENAI_MODEL=gpt-3.5-turbo
LLM_OPENAI_TEMPERATURE=0.1
LLM_OPENAI_MAX_TOKENS=2000
LLM_OPENAI_TOP_P=1.0
LLM_OPENAI_FREQUENCY_PENALTY=0.0
LLM_OPENAI_PRESENCE_PENALTY=0.0
LLM_OPENAI_TIMEOUT=60
LLM_OPENAI_MAX_RETRIES=1

# Gemini
LLM_GEMINI_MODEL=gemini-2.0-flash
LLM_GEMINI_TEMPERATURE=0.1
LLM_GEMINI_MAX_TOKENS=2000
LLM_GEMINI_TOP_P=1.0
LLM_GEMINI_TOP_K=40
LLM_GEMINI_TIMEOUT=60
LLM_GEMINI_MAX_RETRIES=1

# LangChain flags
LLM_VERBOSE=false
LLM_STREAMING=false
LLM_ENABLE_CALLBACKS=true
LLM_ENABLE_CONTENT_FILTER=true

# ===============================
# Qdrant
# ===============================
QDRANT_URL=<YOUR_QDRANT_URL>
QDRANT_API_KEY=<YOUR_QDRANT_API_KEY>
QDRANT_COLLECTION_NAME=milano-agent-qdrant
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine
QDRANT_MAX_RESULTS=5

# ===============================
# S3
# ===============================
S3_BUCKET_NAME=milano-agent
S3_DOCUMENTS_PREFIX=rag-docs/
S3_AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
S3_AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
S3_AWS_REGION=ap-southeast-2

# ===============================
# Embeddings
# ===============================
EMBEDDINGS_MODEL=models/embedding-001
EMBEDDINGS_CHUNK_SIZE=500
EMBEDDINGS_CHUNK_OVERLAP=100
EMBEDDINGS_COHERE_MODEL_ID=cohere.embed-multilingual-v3
EMBEDDINGS_COHERE_INPUT_TYPE=search_document
EMBEDDINGS_COHERE_EMBEDDING_TYPE=float
EMBEDDINGS_COHERE_MAX_BATCH_SIZE=96

# ===============================
# Redis
# ===============================
REDIS_HOST=<YOUR_REDIS_HOST>
REDIS_PORT=<YOUR_REDIS_PORT>
REDIS_USERNAME=default
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD>
REDIS_DB=0
REDIS_URL=<YOUR_REDIS_URL>
REDIS_POOL_SIZE=10
REDIS_CONNECTION_TIMEOUT=30
REDIS_SOCKET_TIMEOUT=30
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30  

# Session-specific
REDIS_DEFAULT_TTL=3600   
REDIS_CACHE_TTL=300      

# ===============================
# Tavily Search
# ===============================
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=advanced
TAVILY_INCLUDE_DOMAINS=["vnexpress.net", "tuoitre.vn", "thanhnien.vn", "dantri.com.vn", "vietnamnet.vn", "laodong.vn", "nld.com.vn", "cafef.vn", "vneconomy.vn", "vietstock.vn", "ndh.vn", "tinnhanhchungkhoan.vn", "stockbiz.vn", "cophieu68.vn", "vietcombank.com.vn", "sbv.gov.vn", "tinhte.vn", "voz.vn", "webtretho.com", "chinhphu.vn", "mpi.gov.vn", "gso.gov.vn"]
TAVILY_TIMEOUT_SECONDS=5

# ===============================
# VnStock
# ===============================
VNSTOCK_TIMEOUT_SECONDS=5
VNSTOCK_INTERVAL=1D
